// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../db/custom.db"
}

// User roles
enum UserRole {
  SUPER_ADMIN
  ADMIN_DESA
  OPERATOR
  WARGA
}

// User status
enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

// Desa/Village data
model Desa {
  id              String   @id @default(cuid())
  
  // Identitas Desa
  namaDesa        String
  kodeDesa        String   @unique
  kodePos         String?
  kecamatan       String
  kabupaten       String
  provinsi        String
  negara          String   @default("Indonesia")
  
  // Kontak
  alamatKantor    String?
  telepon         String?
  email           String?
  website         String?
  
  // Logo & Lambang
  logo            String?        // Logo Desa
  logoKabupaten   String?        // Logo Kabupaten
  logoProvinsi    String?        // Logo Provinsi
  
  // Visi & Misi
  visi            String?
  misi            String?        // JSON array of misi items
  
  // Data Geografis
  luasWilayah     String?        // dalam km² atau ha
  ketinggian      String?        // dalam meter dpl
  curahHujan      String?        // mm/tahun
  batasUtara      String?
  batasSelatan    String?
  batasTimur      String?
  batasBarat      String?
  
  // Sejarah
  tanggalBerdiri  DateTime?
  hariJadi        String?        // Hari jadi desa (tanggal peringatan)
  sejarahSingkat  String?        // Text area untuk sejarah
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  users           User[]
  dusun           Dusun[]
}

// Dusun (Hamlet/Village Subdivision)
model Dusun {
  id              String   @id @default(cuid())
  nama            String
  kode            String?  // Kode dusun
  jumlahKK        Int      @default(0)
  jumlahPenduduk  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  desaId          String?
  desa            Desa?    @relation(fields: [desaId], references: [id], onDelete: Cascade)
  rw              RW[]
  
  // Relations for Kependudukan
  kk              KK[]
  pendatang       Pendatang[]
}

// RW (Rukun Warga)
model RW {
  id              String   @id @default(cuid())
  nomor           String   // Nomor RW (contoh: "001", "002")
  jumlahKK        Int      @default(0)
  jumlahPenduduk  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  dusunId         String
  dusun           Dusun    @relation(fields: [dusunId], references: [id], onDelete: Cascade)
  rt              RT[]
  
  @@unique([dusunId, nomor]) // RW unik per dusun
}

// RT (Rukun Tetangga)
model RT {
  id              String   @id @default(cuid())
  nomor           String   // Nomor RT (contoh: "001", "002")
  jumlahKK        Int      @default(0)
  jumlahPenduduk  Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  rwId            String
  rw              RW       @relation(fields: [rwId], references: [id], onDelete: Cascade)
  
  // Relations for Kependudukan
  kk              KK[]
  pendatang       Pendatang[]
  
  @@unique([rwId, nomor]) // RT unik per RW
}

// User model
model User {
  id                    String      @id @default(cuid())
  namaLengkap           String
  username              String      @unique
  email                 String      @unique
  noHp                  String?
  password              String      // Hashed password
  role                  UserRole    @default(WARGA)
  status                UserStatus  @default(ACTIVE)
  avatar                String?
  isFirstChild          Boolean     @default(false) // First user (super admin)
  faceRecognitionEnabled Boolean    @default(false) // Enable face recognition login
  rfidEnabled           Boolean     @default(false) // Enable RFID login
  lastLoginAt           DateTime?
  failedLoginCount      Int         @default(0)
  lockedUntil           DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  
  desaId                String?
  desa                  Desa?       @relation(fields: [desaId], references: [id])
  sessions              Session[]
  faceData              FaceData?
  rfidCards             RFIDCard[]
  loginAttempts         LoginAttempt[]
  logAktivitas          LogAktivitas[]
  notifikasi            Notifikasi[]
}

// Session management
model Session {
  id              String   @id @default(cuid())
  userId          String
  token           String   @unique
  deviceInfo      String?
  ipAddress       String?
  userAgent       String?
  isActive        Boolean  @default(true)
  lastActivityAt  DateTime @default(now())
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Face recognition data
model FaceData {
  id              String   @id @default(cuid())
  userId          String   @unique
  faceEncoding    String   // JSON string of face descriptor (128 floats)
  faceImage       String?  // Base64 encoded reference image
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// RFID card data
model RFIDCard {
  id              String   @id @default(cuid())
  userId          String
  cardUid         String   @unique
  cardName        String?  // Friendly name for the card
  isActive        Boolean  @default(true)
  lastUsedAt      DateTime?
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Login attempts tracking (anti brute force)
model LoginAttempt {
  id              String   @id @default(cuid())
  userId          String?
  identifier      String   // Username or email used
  ipAddress       String?
  userAgent       String?
  attemptType     String   // PASSWORD, FACE, RFID
  success         Boolean  @default(false)
  failureReason   String?
  createdAt       DateTime @default(now())
  
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Activity Log (Audit Trail)
model LogAktivitas {
  id              String   @id @default(cuid())
  userId          String?
  userName        String   // Store username for historical record
  aksi            String   // Action: LOGIN, LOGOUT, TAKEOVER, CREATE, UPDATE, DELETE, etc.
  modul           String   // Module: USER, PENDUDUK, SURAT, etc.
  deskripsi       String   // Description of the action
  dataRef         String?  // JSON string of affected data reference
  deviceInfo      String?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())
  
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// Notification system
model Notifikasi {
  id              String   @id @default(cuid())
  userId          String   // Target user
  judul           String
  pesan           String
  tipe            String   // INFO, WARNING, SUCCESS, ERROR
  isRead          Boolean  @default(false)
  link            String?  // Optional link to related page
  createdAt       DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Statistics data (for dashboard)
model Statistik {
  id              String   @id @default(cuid())
  tanggal         DateTime @default(now())
  totalPenduduk   Int      @default(0)
  totalKK         Int      @default(0)
  pendatang       Int      @default(0)
  kematian        Int      @default(0)
  kelahiran       Int      @default(0)
  pindah          Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== KEPENDUDUKAN ====================

// Jenis Kelamin
enum JenisKelamin {
  LAKI_LAKI
  PEREMPUAN
}

// Agama
enum Agama {
  ISLAM
  KRISTEN
  KATOLIK
  HINDU
  BUDDHA
  KONGHUCU
  LAINNYA
}

// Status Perkawinan
enum StatusPerkawinan {
  BELUM_KAWIN
  KAWIN_TERCATAT
  KAWIN_TIDAK_TERCATAT
  CERAI_HIDUP_TERCATAT
  CERAI_HIDUP_TIDAK_TERCATAT
  CERAI_MATI
}

// Status Penduduk
enum StatusPenduduk {
  TETAP
  PENDATANG
  PINDAH
  MENINGGAL
}

// Jenis Peristiwa Kependudukan
enum JenisPeristiwa {
  KELAHIRAN
  KEMATIAN
  PINDAH_MASUK
  PINDAH_KELUAR
  PERKAWINAN
  PERCERAIAN
  PENGADOPSIAN
}

// Jenis Tempat Tinggal
enum JenisTempatTinggal {
  MILIK_SENDIRI
  KONTRAK
  SEWA
  RUMAH_ORANGTUA
  RUMAH_SAUDARA
  RUMAH_DINAS
  LAINNYA
}

// Kartu Keluarga (KK)
model KK {
  id              String   @id @default(cuid())
  nomorKK         String   @unique
  
  // Tanggal Terbit KK
  tanggalTerbit   DateTime?
  
  // Jenis Tempat Tinggal
  jenisTempatTinggal JenisTempatTinggal @default(MILIK_SENDIRI)
  
  // Alamat
  alamat          String
  
  // Wilayah (melalui RT)
  rtId            String?
  rt              RT?      @relation(fields: [rtId], references: [id])
  dusunId         String?
  dusun           Dusun?   @relation(fields: [dusunId], references: [id])
  
  // Koordinat
  latitude        String?
  longitude       String?
  
  // Dokumen
  scanKK          String?   // Base64 atau URL foto KK
  fotoRumah       String?   // Base64 atau URL foto rumah
  
  // Kepala Keluarga
  kepalaKeluargaId String?
  
  // Status
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  anggota         Penduduk[]
  peristiwa       PeristiwaKependudukan[]
  
  @@index([nomorKK])
}

// Status KTP
enum StatusKTP {
  BELUM_BUAT
  SUDAH_BUAT
  HILANG
  DALAM_PROSES
}

// Jenis Disabilitas
enum JenisDisabilitas {
  TIDAK_ADA
  FISIK
  NETRA
  RUNGU
  WICARA
  MENTAL
  INTELEKTUAL
  LAINNYA
}

// Kewarganegaraan
enum Kewarganegaraan {
  WNI
  WNA
}

// Penduduk
model Penduduk {
  id                String            @id @default(cuid())
  
  // ========== IDENTITAS ==========
  nik               String            @unique
  namaLengkap       String
  tempatLahir       String?
  tanggalLahir      DateTime?
  jenisKelamin      JenisKelamin
  golonganDarah     String?           // A, B, AB, O
  agama             Agama             @default(ISLAM)
  suku              String?           // Suku/Etnis
  
  // ========== STATUS PERKAWINAN ==========
  statusPerkawinan  StatusPerkawinan  @default(BELUM_KAWIN)
  aktaPerkawinan    String?           // No. Akta Nikah
  tanggalPerkawinan DateTime?         // Tanggal menikah
  aktaPerceraian    String?           // No. Akta Cerai
  tanggalPerceraian DateTime?         // Tanggal cerai
  
  // ========== PEKERJAAN & PENDIDIKAN ==========
  pekerjaan         String?
  pendidikan        String?
  penghasilan       String?           // Range penghasilan
  
  // ========== KEWARGANEGARAAN ==========
  kewarganegaraan   Kewarganegaraan   @default(WNI)
  negaraAsal        String?           // Negara asal (untuk WNA)
  noPaspor          String?
  noKitasKitap      String?
  tanggalMasuk      DateTime?         // Tanggal masuk Indonesia (WNA)
  
  // ========== DOKUMEN ==========
  noAktaKelahiran   String?
  statusKTP         StatusKTP         @default(BELUM_BUAT)
  noBPJSKesehatan   String?
  noBPJSTenagakerja String?
  npwp              String?
  
  // ========== DATA ORANG TUA ==========
  namaAyah          String?
  nikAyah           String?
  namaIbu           String?
  nikIbu            String?
  anakKe            Int?              // Anak ke-berapa
  jumlahSaudara     Int?              // Jumlah saudara kandung
  
  // ========== KARTU KELUARGA ==========
  kkId              String?
  kk                KK?               @relation(fields: [kkId], references: [id])
  hubunganKeluarga  String?           // Kepala Keluarga, Istri, Anak, dll
  urutanDalamKK     Int               @default(1)
  
  // ========== KONTAK ==========
  email             String?
  noHP              String?
  
  // ========== KESEHATAN & DISABILITAS ==========
  jenisNewabilitas  JenisDisabilitas  @default(TIDAK_ADA)
  keteranganDisabilitas String?
  penyakitKronis    String?           // Diabetes, Hipertensi, dll
  
  // ========== STATUS ==========
  status            StatusPenduduk    @default(TETAP)
  isActive          Boolean           @default(true)
  
  // ========== FOTO & DOKUMEN ==========
  foto              String?           // Foto diri
  fotoKTP           String?           // Scan KTP
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  peristiwa         PeristiwaKependudukan[]
  
  @@index([nik])
  @@index([namaLengkap])
  @@index([kkId])
}

// Pendatang Sementara
model Pendatang {
  id                String            @id @default(cuid())
  nik               String?
  namaLengkap       String
  tempatLahir       String?
  tanggalLahir      DateTime?
  jenisKelamin      JenisKelamin
  pekerjaan         String?
  alamatAsal        String
  tujuanKedatangan  String
  noTelp            String?
  
  // Alamat di Desa
  alamat            String?
  rtId              String?
  rt                RT?               @relation(fields: [rtId], references: [id])
  dusunId           String?
  dusun             Dusun?            @relation(fields: [dusunId], references: [id])
  
  // Waktu
  tanggalDatang     DateTime          @default(now())
  tanggalPulang     DateTime?
  lamaTinggal       String?           // dalam hari/bulan
  
  // Status
  isActive          Boolean           @default(true)
  keterangan        String?
  
  // Foto
  foto              String?
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  @@index([namaLengkap])
  @@index([isActive])
}

// Peristiwa Kependudukan
model PeristiwaKependudukan {
  id                String            @id @default(cuid())
  jenisPeristiwa    JenisPeristiwa
  
  // Penduduk terkait
  pendudukId        String?
  penduduk          Penduduk?         @relation(fields: [pendudukId], references: [id])
  
  // KK terkait
  kkId              String?
  kk                KK?               @relation(fields: [kkId], references: [id])
  
  // Detail peristiwa
  tanggalPeristiwa  DateTime          @default(now())
  tempat            String?
  keterangan        String?
  
  // Untuk pindah masuk/keluar
  alamatAsal        String?           // Untuk pindah masuk
  alamatTujuan      String?           // Untuk pindah keluar
  
  // Untuk kematian
  penyebabKematian  String?
  
  // Untuk kelahiran
  namaBayi          String?
  jenisKelaminBayi  JenisKelamin?
  beratBayi         String?
  panjangBayi       String?
  
  // Status
  isProcessed       Boolean           @default(false)
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  @@index([jenisPeristiwa])
  @@index([tanggalPeristiwa])
}

// Monitoring Data Kependudukan
model MonitoringData {
  id                String            @id @default(cuid())
  periode           DateTime          @default(now())  // Bulan/Tahun
  bulan             Int               @default(1)
  tahun             Int               @default(2024)
  
  // Statistik
  totalPenduduk     Int               @default(0)
  totalLakiLaki     Int               @default(0)
  totalPerempuan    Int               @default(0)
  totalKK           Int               @default(0)
  
  // Perubahan
  kelahiran         Int               @default(0)
  kematian          Int               @default(0)
  pindahMasuk       Int               @default(0)
  pindahKeluar      Int               @default(0)
  
  // Pendatang
  pendatangAktif    Int               @default(0)
  
  // Peristiwa
  perkawinan        Int               @default(0)
  perceraian        Int               @default(0)
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  @@unique([bulan, tahun])
}
